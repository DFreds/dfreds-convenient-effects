{
    "compilerOptions": {
        "target": "es2024",
        "module": "NodeNext",
        "moduleResolution": "NodeNext",
        "lib": [
            "ES2024",
            "ESNext.Array",
            "ESNext.AsyncIterable",
            "ESNext.Collection",
            "ESNext.Intl",
            "ESNext.Iterator",
            "ESNext.Promise",
            "DOM",
            "DOM.Iterable",
            "DOM.AsyncIterable"
        ],
        "noEmit": true,
        "strict": true,
        "noFallthroughCasesInSwitch": true,
        "skipLibCheck": true,
        "noImplicitOverride": true,
        "noImplicitReturns": true,
        "noUnusedLocals": true,
        "noUnusedParameters": true,
        "allowImportingTsExtensions": true,
        "forceConsistentCasingInFileNames": true,
        "esModuleInterop": true,
        "sourceMap": true,
        "isolatedModules": true,
        "outDir": "dist",
        "allowUnusedLabels": false,
        "allowUmdGlobalAccess": true,
        "removeComments": false,
        "resolveJsonModule": true,
        "useDefineForClassFields": true,
        "noErrorTruncation": true,
        "paths": {
            "@static/*": ["./static/*"],
            "@common/*": ["./types/foundry/common/*"],
            "@client/*": ["./types/foundry/client/*"]
        },
        "types": ["jest", "jquery", "node"],
        "typeRoots": ["./node_modules/@types", "./types/foundry"]
    },
    "include": [
        "./src/**/*",
        "./tests/**/*.ts",
        "./types/foundry/global-external.d.mts",
        "./types/convenientEffects/index.d.ts",
        "./types/libWrapper/index.d.ts",
        "./types/socketlib/index.d.ts",
        "./types/statusEffects/index.d.ts",
        "./types/uiExtender/index.d.ts",
        "./types/migrations/index.d.ts",
        "./vite.config.ts"
    ],
    "watchOptions": {
        "fallbackPolling": "dynamicpriority",
        "excludeDirectories": ["dist", "packs", "static"]
    }
}
