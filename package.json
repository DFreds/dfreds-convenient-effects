{
    "name": "dfreds-convenient-effects",
    "version": "1.0.0",
    "description": "Adds easy to use toggleable active effects for common use cases",
    "private": true,
    "type": "module",
    "scripts": {
        "build": "tsc && vite build",
        "stage": "tsc && npm run clean && vite build --mode stage",
        "dev": "tsc && npm run clean && vite build --mode development",
        "clean": "tsx ./build/clean.ts",
        "foundry": "tsx ./build/start-foundry.ts",
        "hot": "vite serve",
        "watch": "tsc && npm run clean && vite build --watch --mode development",
        "link": "tsx ./build/link-foundry.ts",
        "update-types": "tsx ./build/update-pf2e-types.ts && tsx ./build/copy-pf2e-types.ts",
        "test": "jest",
        "lint": "npm run lint:ts && npm run lint:json && npm run prettier:scss",
        "lint:ts": "eslint ./src --ext .ts",
        "prettier:scss": "prettier --check src/styles",
        "lint:json": "eslint ./static --ext .json --no-eslintrc --plugin json --rule \"json/*: error\" --rule \"linebreak-style: error\"",
        "lint:fix": "eslint ./src --ext .ts --fix && prettier --write src/styles"
    },
    "author": "DFreds (https://github.com/DFreds)",
    "license": "MIT",
    "engines": {
        "node": ">=24.14.1"
    },
    "dependencies": {},
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@eslint/json": "^1.2.0",
        "@pixi/basis": "7.4.3",
        "@pixi/graphics-smooth": "1.1.1",
        "@pixi/particle-emitter": "5.0.10",
        "@sveltejs/vite-plugin-svelte": "^7.0.0",
        "@types/fs-extra": "^11.0.4",
        "@types/jest": "^30.0.0",
        "@types/jquery": "^4.0.0",
        "@types/jsdom": "^28.0.1",
        "@types/luxon": "^3.7.1",
        "@types/node": "^25.6.0",
        "@types/prompts": "^2.4.9",
        "@types/showdown": "^2.0.6",
        "@types/simple-peer": "^9.11.9",
        "@types/sortablejs": "^1.15.9",
        "@types/tooltipster": "^0.0.35",
        "@types/yaireo__tagify": "4.17.0",
        "classic-level": "^3.0.0",
        "es-jest": "^2.1.0",
        "eslint": "^10.3.0",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-prettier": "^5.5.5",
        "fs-extra": "^11.3.4",
        "glob": "^13.0.6",
        "globals": "^17.6.0",
        "gsap": "3.11.5",
        "handlebars": "4.7.9",
        "jest": "^30.3.0",
        "jest-each": "^30.3.0",
        "js-angusj-clipper": "^1.3.1",
        "jsdom": "^29.1.1",
        "peggy": "^5.1.0",
        "pixi.js": "7.4.3",
        "prettier": "^3.8.3",
        "prettier-plugin-svelte": "^3.5.1",
        "prompts": "^2.4.2",
        "prosemirror-collab": "^1.3.1",
        "prosemirror-commands": "^1.7.1",
        "prosemirror-dropcursor": "^1.8.2",
        "prosemirror-gapcursor": "^1.4.1",
        "prosemirror-history": "^1.5.0",
        "prosemirror-inputrules": "^1.5.1",
        "prosemirror-keymap": "^1.2.3",
        "prosemirror-model": "^1.25.4",
        "prosemirror-schema-list": "^1.5.1",
        "prosemirror-state": "^1.4.4",
        "prosemirror-tables": "^1.8.5",
        "prosemirror-transform": "^1.12.0",
        "prosemirror-view": "^1.41.8",
        "sass": "^1.99.0",
        "socket.io": "4.8.3",
        "socket.io-client": "4.8.3",
        "svelte-preprocess": "^6.0.3",
        "tsx": "^4.21.0",
        "typescript": "^5.9.3",
        "typescript-eslint": "^8.59.1",
        "vite": "^8.0.10",
        "vite-plugin-checker": "^0.13.0",
        "vite-plugin-static-copy": "^4.1.0",
        "yargs": "^18.0.0"
    }
}
